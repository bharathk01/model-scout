# Copy to .env and fill in the provider you want. The .env file is gitignored.
# Only set the block for the provider named in MODEL_PROVIDER.

MODEL_PROVIDER=anthropic          # anthropic | azure | gemini | local
MODEL_NAME=claude-sonnet-5

# --- anthropic ---
ANTHROPIC_API_KEY=

# --- azure (MODEL_NAME = your deployment name) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_API_KEY=

# --- gemini ---
# GOOGLE_API_KEY=

# --- local (vLLM / Ollama / LM Studio / SGLang / TGI) ---
# LOCAL_MODEL_BASE_URL=http://localhost:8000/v1
# LOCAL_MODEL_API_KEY=not-needed

# --- email notification (optional) ---
# Set all of these to email the digest. If any is missing, ModelScout just
# saves the digest to ./digests/ instead. For Gmail, use an App Password
# (not your account password) with SMTP_HOST=smtp.gmail.com SMTP_PORT=587.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=
# EMAIL_TO=
